{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pik Pro Player",
  "version": "0.1.0",
  "identifier": "com.mickydigitalstudio.pikproplayer",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Pik Pro Player",
        "width": 1500,
        "height": 940,
        "minWidth": 1100,
        "minHeight": 700,
        "center": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": []
  }
}
